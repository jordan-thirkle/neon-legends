{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/studio", "destination": "/studio/index.html" },
    { "source": "/neon-legends", "destination": "/game/index.html" },
    { "source": "/neon-legends/:path*", "destination": "/game/:path*" },
    { "source": "/", "destination": "/studio/index.html" }
  ],
  "headers": [
    {
      "source": "/game/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    }
  ]
}
